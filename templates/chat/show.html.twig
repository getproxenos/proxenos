{% extends 'base.html.twig' %}

{% block title %}Chat — Proxenos{% endblock %}

{% block body %}
    <header>
        <h1>Proxenos chat</h1>
        <p>
            <a href="{{ path('chat_new') }}">New thread</a>
            &middot;
            <a href="{{ path('me') }}">Account</a>
        </p>
    </header>

    <aside>
        <h2>Threads</h2>
        {% if thread_list is empty %}
            <p><em>No threads yet — send a message below to start one.</em></p>
        {% else %}
            <ul>
                {% for t in thread_list %}
                    <li>
                        <a href="{{ path('chat_show', {threadId: t.id}) }}"><code>{{ t.id }}</code></a>
                        <small>updated {{ t.updatedAt|date('Y-m-d H:i:s') }}</small>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}
    </aside>

    <section>
        <h2>Thread <code>{{ thread_id }}</code></h2>

        {% for flash in app.flashes('error') %}
            <p style="color: red;">{{ flash }}</p>
        {% endfor %}

        {% if not thread_exists %}
            <p><em>New thread — submit a message to materialize it.</em></p>
        {% endif %}

        <ol class="messages" id="messages">
            {# ADR-025: assistant turns that hit a platform error are folded to
               `failed` by the assistant_turn_failed event. Rendering the status
               verbatim is now honest — no more synthetic "(incomplete)" marker
               (that one assumed the only stuck state was an unhandled
               STREAMING). A rare lingering `streaming` row would mean the
               failure event itself never landed (e.g. a crash inside
               EventAppender) and is still surfaced via the raw status text. #}
            {% for m in messages %}
                <li class="message message-{{ m.role }} message-status-{{ m.status }}">
                    <strong>{{ m.role|capitalize }}</strong>
                    <small>{{ m.created_at|date('Y-m-d H:i:s') }} — {{ m.status }}</small>
                    <pre>{{ m.text }}</pre>
                </li>
            {% endfor %}
        </ol>

        <ol class="messages" id="live-stream" hidden>
            <li class="message message-user">
                <strong>User</strong>
                <pre id="live-user"></pre>
            </li>
            <li class="message message-assistant">
                <strong>Assistant</strong>
                <small>streaming…</small>
                <pre id="live-assistant"></pre>
            </li>
        </ol>

        <form id="chat-form"
              method="post"
              action="{{ path('chat_submit', {threadId: thread_id}) }}"
              data-stream-action="{{ path('chat_submit_stream', {threadId: thread_id}) }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('chat') }}">
            <label for="text">Your message</label>
            <textarea id="text" name="text" rows="4" cols="80" required autofocus></textarea>
            <div>
                <button type="submit">Send</button>
            </div>
        </form>
    </section>

    {# Inline SSE consumer — Phase 0.4. Intentionally dumb: no cursor, no
       replay, no reconnect. On stream completion we reload the page so the
       server-rendered projection is the source of truth. JS-disabled
       browsers fall back to the form's regular POST + redirect. #}
    <script>
    (function () {
        const form = document.getElementById('chat-form');
        if (!form || !window.fetch || !window.ReadableStream) {
            return;
        }
        const streamAction = form.dataset.streamAction;
        if (!streamAction) {
            return;
        }
        const liveBox = document.getElementById('live-stream');
        const liveUser = document.getElementById('live-user');
        const liveAssistant = document.getElementById('live-assistant');

        form.addEventListener('submit', async function (event) {
            event.preventDefault();
            const text = form.querySelector('textarea[name="text"]').value;
            if (!text.trim()) {
                return;
            }
            liveUser.textContent = text;
            liveAssistant.textContent = '';
            liveBox.hidden = false;
            form.querySelector('button[type="submit"]').disabled = true;

            const fd = new FormData(form);
            let response;
            try {
                response = await fetch(streamAction, {
                    method: 'POST',
                    body: fd,
                    headers: { Accept: 'text/event-stream' },
                    credentials: 'same-origin',
                });
            } catch (e) {
                // Safe to retry: fetch() rejects before any HTTP exchange
                // completes. The streaming controller's loop only runs inside
                // the StreamedResponse body — that body is only consumed by the
                // server after the 200 status/headers ship — so a fetch
                // rejection means the loop never appended any events. The
                // plain form POST goes to /messages, which is the same loop
                // but synchronous; one turn either way.
                form.submit();
                return;
            }
            if (!response.ok || !response.body) {
                // Same reasoning: a non-200 response means the controller
                // bailed before constructing the StreamedResponse (CSRF,
                // tenant, empty text, auth redirect). The loop never ran, so
                // resubmitting through the form path can't double-post.
                form.submit();
                return;
            }

            const reader = response.body.getReader();
            const decoder = new TextDecoder();
            let buffer = '';
            let lastEvent = null;
            while (true) {
                const { value, done } = await reader.read();
                if (done) break;
                buffer += decoder.decode(value, { stream: true });
                let sep;
                while ((sep = buffer.indexOf('\n\n')) >= 0) {
                    const raw = buffer.slice(0, sep);
                    buffer = buffer.slice(sep + 2);
                    const dataLine = raw.split('\n').find(function (l) { return l.startsWith('data: '); });
                    if (!dataLine) continue;
                    let payload;
                    try {
                        payload = JSON.parse(dataLine.slice(6));
                    } catch (e) {
                        continue;
                    }
                    lastEvent = payload;
                    if (payload.type === 'delta' && typeof payload.text === 'string') {
                        liveAssistant.textContent = payload.text;
                    } else if (payload.type === 'error') {
                        liveAssistant.textContent = '[error] ' + (payload.message || 'unknown');
                    }
                }
            }
            if (lastEvent && lastEvent.type === 'done') {
                window.location.reload();
            } else {
                form.querySelector('button[type="submit"]').disabled = false;
            }
        });
    })();
    </script>
{% endblock %}
