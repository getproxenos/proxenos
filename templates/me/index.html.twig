{% extends 'base.html.twig' %}

{% block title %}Signed in — bug-free-happiness{% endblock %}

{% block body %}
    <h1>Signed in</h1>

    <dl>
        <dt>Email</dt>
        <dd>{{ user.email }}</dd>

        <dt>User URI</dt>
        <dd><code>{{ user.coreUri }}</code></dd>

        {% if membership %}
            <dt>Tenant</dt>
            <dd>{{ membership.tenant.name }} ({{ membership.tenant.slug }})</dd>

            <dt>Tenant URI</dt>
            <dd><code>{{ membership.tenant.coreUri }}</code></dd>

            <dt>Role</dt>
            <dd>{{ membership.role.value }}</dd>
        {% else %}
            <dt>Tenant</dt>
            <dd><em>none (mint one with <code>app:tenant:create</code> and attach with <code>app:user:create</code>)</em></dd>
        {% endif %}
    </dl>

    <form method="post" action="{{ path('logout') }}">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">
        <button type="submit">Sign out</button>
    </form>
{% endblock %}
