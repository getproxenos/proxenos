# =============================================================================
# .env — committed defaults (NO secrets). Override locally in .env.local
# (gitignored) and in deploy via real environment variables / Coolify secrets.
# =============================================================================

# === Application ===
APP_ENV=dev
APP_SECRET=change-me-set-in-env-local

# === Trusted proxies (behind FrankenPHP/Caddy + Coolify) ===
TRUSTED_PROXIES=127.0.0.1,REMOTE_ADDR,private_ranges

# === Database (PostgreSQL + pgvector) ===
# serverVersion pins the platform so Doctrine emits Postgres SQL without a
# connection round-trip. The compose `db` service is pgvector/pgvector:pg16.
DATABASE_URL="postgresql://app:app@db:5432/app?serverVersion=16&charset=utf8"

# === Messenger ===
# Async transport present-but-unused in Phase 0 (compaction/operations need it
# later). Doctrine-backed on Postgres; consume with `messenger:consume async`.
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=true

# === Mercure (FrankenPHP built-in hub) ===
# The app container runs FrankenPHP, which also serves the Mercure hub at
# /.well-known/mercure (enabled via CADDY_SERVER_EXTRA_DIRECTIVES in compose).
# MERCURE_JWT_SECRET must match the value Caddy is given. Wired but unused until 0.3.
MERCURE_URL=http://app:8080/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost:8080/.well-known/mercure
MERCURE_JWT_SECRET=!ChangeThisDevMercureJwtSecret!

# === symfony/ai Platform (ADR-019, ADR-023, Platform-only) ===
# Two bridges configured in config/packages/ai.yaml. The model-profile resolver
# (proxenos.task.chat, ...) picks which one to use per profile via
# proxenos.yaml.
#
# Anthropic bridge (default behind proxenos.task.chat). Leave empty in
# committed defaults; set in .env.local for live runs. The test suite uses
# Symfony\AI\Platform\Test\InMemoryPlatform so make test runs key-free.
ANTHROPIC_API_KEY=

# Generic OpenAI-compatible bridge (Phase 0.0). Empty LLM_BASE_URL leaves the
# client "unconfigured" (LlmConfig::isConfigured() === false). Point it at any
# OpenAI-compatible server — e.g. a local Ollama at http://host:11434/v1 for a
# key-free smoke test, or a hosted endpoint with LLM_API_KEY set. Also the
# second bridge used to verify the resolver's "swap by config" DoD.
LLM_BASE_URL=
LLM_API_KEY=
LLM_CHAT_MODEL=
LLM_EMBEDDING_MODEL=
EMBEDDING_DIM=1024
