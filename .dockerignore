# =============================================================================
# .dockerignore — Proxenos
# =============================================================================
# Keep the COPY . build context small and free of secrets/generated artifacts.

# Dependencies / generated (reinstalled or regenerated inside the image)
/vendor/
/var/

# Docker tooling + host orchestration (not needed in the image)
/docker/
# …except the PHP conf.d overrides, which the Dockerfile copies into
# /usr/local/etc/php/conf.d/ at build time (see Dockerfile base stage).
!/docker/php/conf.d/
docker-bake.hcl
Makefile

# Version control / CI / editor / OS noise
/.git/
/.gitignore
/.gitattributes
/.github/
/.idea/
/.vscode/
/.claude/
/.direnv/
/.envrc
*.swp
.DS_Store

# Nix dev shell
/flake.nix
/flake.lock

# Local env overrides — never bake into an image
/.env.local
/.env.*.local

# Compose overlays (used outside the image)
/compose.*.yaml

# PHP tooling caches
/.phpunit.cache/
/.php-cs-fixer.cache

# Frontend: node_modules never enters the image; the prod SPA build is produced by
# the Dockerfile `frontend` (Node) stage, not copied from the host context.
/frontend/node_modules/
/public/app/

# Python venv for Markdown tooling (mdformat)
/.venv/
/.ruff_cache/

# Planning docs — not part of the runtime image
/current-handoffs/
/design-notes/
/handoffs/
/reference/
/architecture-decisions.md
/open-questions.md
/overview.md
