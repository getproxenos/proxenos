extends: default

rules:
  line-length: disable
  document-start: disable
  truthy:
    check-keys: false
  comments:
    min-spaces-from-content: 1
  indentation:
    # Symfony config uses 4-space, compose/CI use 2-space — accept either as long
    # as each file is internally consistent.
    spaces: consistent
    indent-sequences: consistent

ignore: |
  /vendor/
  /var/
  /.direnv/
  /frontend/
