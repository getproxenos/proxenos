# Test environment overrides. Loaded after .env when APP_ENV=test.
APP_ENV=test
APP_SECRET=test-secret

# In-memory transport keeps the suite isolated from a real broker/DB queue.
MESSENGER_TRANSPORT_DSN=in-memory://

# The functional/integration suites that touch the DB expect a Postgres reachable
# at this DSN (override in CI / locally as needed).
DATABASE_URL="postgresql://app:app@127.0.0.1:5433/app_test?serverVersion=16&charset=utf8"

MERCURE_URL=http://localhost/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost/.well-known/mercure
MERCURE_JWT_SECRET=test-mercure-secret
